<div id="homepage" v-cloak>
  <div class="page-content">
    <section class="section">
      <!-- Hero Section -->
      <div class="text-center py-5">
        <div class="mb-4">
          <i class="bi bi-shield-check" style="font-size: 4rem; color: var(--bs-primary);"></i>
        </div>
        <h1 class="display-5 fw-bold mb-3">ExArt26 IOTA</h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">
          Gestione decentralizzata delle liste d'attesa per la riabilitazione sanitaria
          (Ex Art. 26) su tecnologia blockchain IOTA/Shimmer.
        </p>
        <div class="d-flex justify-content-center gap-3 mt-4">
          <a href="/dashboard" class="btn btn-primary btn-lg">
            <i class="bi bi-speedometer2 me-2"></i>Vai alla Dashboard
          </a>
          <a href="/wallet/verifica" class="btn btn-outline-secondary btn-lg">
            <i class="bi bi-wallet2 me-2"></i>Stato Wallet
          </a>
        </div>
      </div>

      <!-- Features -->
      <div class="row g-4 mt-3 mb-5">
        <div class="col-12 col-md-4">
          <div class="card h-100 text-center">
            <div class="card-body py-4">
              <div class="stats-icon purple mb-3 mx-auto">
                <i class="iconly-boldCategory"></i>
              </div>
              <h5>Organizzazioni</h5>
              <p class="text-muted mb-0">Gestisci organizzazioni e strutture sanitarie con identità crittografica verificabile.</p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-4">
              <a href="/organizzazioni" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-arrow-right me-1"></i>Gestisci
              </a>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card h-100 text-center">
            <div class="card-body py-4">
              <div class="stats-icon green mb-3 mx-auto">
                <i class="iconly-boldDocument"></i>
              </div>
              <h5>Liste d'Attesa</h5>
              <p class="text-muted mb-0">Crea e monitora le liste d'attesa con trasparenza garantita dalla blockchain.</p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-4">
              <a href="/strutture" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-arrow-right me-1"></i>Visualizza
              </a>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card h-100 text-center">
            <div class="card-body py-4">
              <div class="stats-icon red mb-3 mx-auto">
                <i class="iconly-boldProfile"></i>
              </div>
              <h5>Assistiti</h5>
              <p class="text-muted mb-0">Registra pazienti con dati protetti da crittografia ibrida RSA+AES.</p>
            </div>
            <div class="card-footer bg-transparent border-0 pb-4">
              <a href="/assistiti" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-arrow-right me-1"></i>Gestisci
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Info Section -->
      <div class="card">
        <div class="card-body">
          <div class="row align-items-center">
            <div class="col-12 col-md-8">
              <h5 class="mb-2"><i class="bi bi-shield-lock me-2 text-primary"></i>Sicurezza e Trasparenza</h5>
              <p class="text-muted mb-0">
                Tutti i dati sensibili vengono cifrati con crittografia ibrida (RSA-2048 + AES-256-CBC)
                e registrati come payload sulla rete IOTA. Le operazioni sono immutabili e verificabili,
                garantendo la massima trasparenza nella gestione delle liste d'attesa sanitarie.
              </p>
            </div>
            <div class="col-12 col-md-4 text-center mt-3 mt-md-0">
              <i class="bi bi-link-45deg" style="font-size: 4rem; opacity: 0.15;"></i>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>
<%- /* Expose locals as `window.SAILS_LOCALS` :: */ exposeLocalsToBrowser() %>
