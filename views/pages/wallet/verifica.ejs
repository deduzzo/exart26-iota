
<div id="verifica">

    <% if (networkError) { %>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="alert alert-warning" role="alert">
                        <strong>Errore di connessione alla rete IOTA!</strong><br>
                        <code><%= networkError %></code><br><br>
                        Verificare che il nodo configurato sia raggiungibile:<br>
                        <strong><%= iotaNetwork %></strong><br><br>
                        <small>Controllare il file <code>config/private_iota_conf.js</code> e aggiornare <code>IOTA_NODE_URL</code> con un nodo attivo.</small>
                    </div>
                </div>
            </div>
        </div>
    <% } else if (!isWalletInitialized) { %>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="alert alert-danger" role="alert">
                        <strong>Attenzione!</strong> Non hai ancora inizializzato il tuo wallet. <a
                                href="/wallet/verifica?initWallet=true">Clicca qui</a> per inizializzarlo.
                    </div>
                </div>
            </div>
        </div>
    <% } else if (mnemonic) { %>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="alert alert-success" role="alert">
                        <strong>Complimenti!</strong> Il tuo wallet e stato inizializzato correttamente, <strong>qui sotto trovi la frase segreta, conservala con cura!</strong> Aggiungere inoltre dei fondi all'indirizzo: <br /><strong><%= mainAddress %></strong><br />
                        Rete: <%= iotaNetwork %>
                    </div>
                </div>
                <div class="col-md-12">
                    <h3>Frase segreta</h3>
                    <div class="alert alert-info" role="alert">
                        <strong><%= mnemonic %></strong>
                    </div>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="alert alert-success" role="alert">
                        Il tuo wallet e gia stato inizializzato correttamente: <br />MainAddress: <strong><%= mainAddress %></strong><br />Balance: <strong><%= balance %></strong> </div>
                </div>
            </div>
        </div>
    <% } %>

</div>
<%- /* Expose server-rendered data as window.SAILS_LOCALS :: */ exposeLocalsToBrowser() %>
