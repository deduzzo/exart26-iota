<div class="page-content">
    <section class="row">
        <div class="col-12">
            <div class="row">
                <!-- Organizzazioni -->
                <div class="col-6 col-lg-3 col-md-6">
                    <div class="card">
                        <div class="card-body px-4 py-4-5">
                            <div class="row">
                                <div class="col-md-4 col-lg-12 col-xl-12 col-xxl-5 d-flex justify-content-start">
                                    <div class="stats-icon purple mb-2">
                                        <i class="iconly-boldCategory"></i>
                                    </div>
                                </div>
                                <div class="col-md-8 col-lg-12 col-xl-12 col-xxl-7">
                                    <h6 class="text-muted font-semibold">Organizzazioni</h6>
                                    <h6 class="font-extrabold mb-0"><%= stats.organizzazioni %></h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Strutture -->
                <div class="col-6 col-lg-3 col-md-6">
                    <div class="card">
                        <div class="card-body px-4 py-4-5">
                            <div class="row">
                                <div class="col-md-4 col-lg-12 col-xl-12 col-xxl-5 d-flex justify-content-start">
                                    <div class="stats-icon blue mb-2">
                                        <i class="iconly-boldHome"></i>
                                    </div>
                                </div>
                                <div class="col-md-8 col-lg-12 col-xl-12 col-xxl-7">
                                    <h6 class="text-muted font-semibold">Strutture</h6>
                                    <h6 class="font-extrabold mb-0"><%= stats.strutture %></h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Liste Attesa -->
                <div class="col-6 col-lg-3 col-md-6">
                    <div class="card">
                        <div class="card-body px-4 py-4-5">
                            <div class="row">
                                <div class="col-md-4 col-lg-12 col-xl-12 col-xxl-5 d-flex justify-content-start">
                                    <div class="stats-icon green mb-2">
                                        <i class="iconly-boldDocument"></i>
                                    </div>
                                </div>
                                <div class="col-md-8 col-lg-12 col-xl-12 col-xxl-7">
                                    <h6 class="text-muted font-semibold">Liste d'Attesa</h6>
                                    <h6 class="font-extrabold mb-0"><%= stats.liste %> <small class="text-muted">(<%= stats.listeAperte %> aperte)</small></h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Assistiti -->
                <div class="col-6 col-lg-3 col-md-6">
                    <div class="card">
                        <div class="card-body px-4 py-4-5">
                            <div class="row">
                                <div class="col-md-4 col-lg-12 col-xl-12 col-xxl-5 d-flex justify-content-start">
                                    <div class="stats-icon red mb-2">
                                        <i class="iconly-boldProfile"></i>
                                    </div>
                                </div>
                                <div class="col-md-8 col-lg-12 col-xl-12 col-xxl-7">
                                    <h6 class="text-muted font-semibold">Assistiti</h6>
                                    <h6 class="font-extrabold mb-0"><%= stats.assistiti %> <small class="text-muted">(<%= stats.assistitiInCoda %> in coda)</small></h6>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <!-- Stato Wallet -->
                <div class="col-12 col-xl-4">
                    <div class="card">
                        <div class="card-header">
                            <h4>Stato Blockchain</h4>
                        </div>
                        <div class="card-body">
                            <% if (walletInitialized) { %>
                                <div class="d-flex align-items-center mb-3">
                                    <span class="badge bg-success rounded-pill me-2">Attivo</span>
                                    <span>Wallet IOTA inizializzato</span>
                                </div>
                            <% } else { %>
                                <div class="d-flex align-items-center mb-3">
                                    <span class="badge bg-danger rounded-pill me-2">Non attivo</span>
                                    <span>Wallet non inizializzato</span>
                                </div>
                                <a href="/wallet/verifica" class="btn btn-outline-primary btn-sm">Inizializza Wallet</a>
                            <% } %>
                            <hr>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Organizzazioni su blockchain</span>
                                <span class="font-bold"><%= stats.organizzazioni %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Strutture su blockchain</span>
                                <span class="font-bold"><%= stats.strutture %></span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Liste su blockchain</span>
                                <span class="font-bold"><%= stats.liste %></span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Assistiti su blockchain</span>
                                <span class="font-bold"><%= stats.assistiti %></span>
                            </div>
                        </div>
                    </div>

                    <!-- Azioni rapide -->
                    <div class="card">
                        <div class="card-header">
                            <h4>Azioni Rapide</h4>
                        </div>
                        <div class="card-body d-grid gap-2">
                            <a href="/organizzazioni" class="btn btn-outline-primary btn-sm">
                                <i class="iconly-boldCategory"></i> Gestisci Organizzazioni
                            </a>
                            <a href="/assistiti" class="btn btn-outline-primary btn-sm">
                                <i class="iconly-boldProfile"></i> Gestisci Assistiti
                            </a>
                            <a href="/wallet/verifica" class="btn btn-outline-primary btn-sm">
                                <i class="iconly-boldWallet"></i> Verifica Wallet
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Ultime Operazioni -->
                <div class="col-12 col-xl-8">
                    <div class="card">
                        <div class="card-header">
                            <h4>Ultime Operazioni</h4>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover table-lg">
                                    <thead>
                                    <tr>
                                        <th>Assistito</th>
                                        <th>Lista</th>
                                        <th>Stato</th>
                                        <th>Data</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    <% if (ultimeOperazioni.length === 0) { %>
                                        <tr>
                                            <td colspan="4" class="text-center text-muted">Nessuna operazione registrata</td>
                                        </tr>
                                    <% } %>
                                    <% ultimeOperazioni.forEach(function(op) { %>
                                        <tr>
                                            <td>
                                                <% if (op.assistito) { %>
                                                    <%= op.assistito.cognome %> <%= op.assistito.nome %>
                                                <% } else { %>
                                                    <span class="text-muted">ID: <%= op.assistito %></span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (op.lista && op.lista.denominazione) { %>
                                                    <%= op.lista.denominazione %>
                                                <% } else { %>
                                                    <span class="text-muted">-</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (op.stato === 1) { %>
                                                    <span class="badge bg-info">In coda</span>
                                                <% } else if (op.stato === 2) { %>
                                                    <span class="badge bg-warning">In assistenza</span>
                                                <% } else if (op.stato === 3) { %>
                                                    <span class="badge bg-success">Completato</span>
                                                <% } else if (op.stato === 4) { %>
                                                    <span class="badge bg-secondary">Cambio lista</span>
                                                <% } else if (op.stato === 5) { %>
                                                    <span class="badge bg-danger">Rinuncia</span>
                                                <% } else if (op.stato === 6) { %>
                                                    <span class="badge bg-dark">Annullato</span>
                                                <% } %>
                                            </td>
                                            <td>
                                                <% if (op.dataOraIngresso) { %>
                                                    <%= new Date(op.dataOraIngresso).toLocaleDateString('it-IT') %>
                                                <% } else { %>
                                                    <%= new Date(op.createdAt).toLocaleDateString('it-IT') %>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<%- /* Expose server-rendered data as window.SAILS_LOCALS :: */ exposeLocalsToBrowser() %>
