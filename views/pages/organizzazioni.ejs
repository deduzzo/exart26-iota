<div id="organizzazioni" v-cloak>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('addOrganizzazioneForm');
        form.onsubmit = function (event) {
          event.preventDefault(); // Previene il submit normale del form

          // Validazione
          const denominazione = form.querySelector('#denominazione');
          if (!denominazione.value.trim()) {
            denominazione.classList.add('is-invalid');
            return;
          }
          denominazione.classList.remove('is-invalid');

          // Disabilita il pulsante di submit e mostra il loader
          const submitButton = form.querySelector('button[type="submit"]');
          submitButton.disabled = true;
          document.getElementById('loadingText').style.display = 'inline-block';

          // Prepara i dati del form per l'invio
          const formData = new FormData(form);

          // Effettua la richiesta AJAX
          fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
              'X-CSRF-Token': form.querySelector('[name="_csrf"]').value
            }
          }).then(response => {
            if (response.ok) {
              // Ricarica la pagina se la richiesta ha avuto successo
              window.location.reload();
            } else {
              console.error('Error:', JSON.stringify(response));
              alert(JSON.stringify(response));
            }
          }).catch(error => {
            console.error('Error:', error);
            alert(JSON.stringify(error));
          }).finally(() => {
            // Ripristina l'interfaccia utente
            submitButton.disabled = false;
            document.getElementById('loadingText').style.display = 'none';
          });
        };
      });
    </script>

    <!-- Modal Nuova Organizzazione -->
    <div class="modal fade" id="inlineForm" tabindex="-1" aria-labelledby="modalNuovaOrg" aria-hidden="true"
         data-bs-backdrop="static" data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary bg-opacity-10">
                    <h5 class="modal-title" id="modalNuovaOrg">
                        <i class="bi bi-plus-circle me-2"></i>Nuova Organizzazione
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                </div>
                <form id="addOrganizzazioneForm" action="/api/v1/add-organizzazione" method="POST">
                    <input type="hidden" name="_csrf" value="<%- _csrf %>">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="denominazione" class="form-label fw-semibold">Denominazione</label>
                            <input id="denominazione" name="denominazione" type="text" class="form-control"
                                   placeholder="Inserisci il nome dell'organizzazione" required>
                            <div class="invalid-feedback">La denominazione è obbligatoria.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annulla</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Salva
                        </button>
                        <span id="loadingText" class="ms-2" style="display:none;">
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            Registrazione su blockchain...
                        </span>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="page-content">
        <section class="section">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                    <% if (!id) { %>
                        <li class="breadcrumb-item active" aria-current="page">Organizzazioni</li>
                    <% } else { %>
                        <li class="breadcrumb-item"><a href="/organizzazioni">Organizzazioni</a></li>
                        <li class="breadcrumb-item active" aria-current="page"><%= organizzazioni.denominazione %></li>
                    <% } %>
                </ol>
            </nav>

            <% if (!id) { %>
                <!-- Header con azione -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="mb-1">Organizzazioni</h3>
                        <p class="text-muted mb-0">Gestisci le organizzazioni sanitarie registrate sulla blockchain</p>
                    </div>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#inlineForm">
                        <i class="bi bi-plus-lg me-1"></i>Nuova Organizzazione
                    </button>
                </div>

                <% if (organizzazioni.length === 0) { %>
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-building" style="font-size: 3rem; opacity: 0.3;"></i>
                            <h5 class="mt-3 text-muted">Nessuna organizzazione presente</h5>
                            <p class="text-muted">Inizia aggiungendo la prima organizzazione sanitaria.</p>
                            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#inlineForm">
                                <i class="bi bi-plus-lg me-1"></i>Aggiungi Organizzazione
                            </button>
                        </div>
                    </div>
                <% } else { %>
                    <div class="row">
                        <% organizzazioni.forEach((organizzazione) => { %>
                            <div class="col-12 col-md-6 col-lg-4 mb-3">
                                <%- include('../layouts/partials/card-organizzazione', {organizzazione}); %>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            <% } %>

            <% if (id) { %>
                <!-- Dettaglio singola organizzazione -->
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="bi bi-building me-2"></i><%= organizzazioni.denominazione %>
                        </h4>
                        <span class="badge bg-primary">#<%= id %></span>
                    </div>
                    <div class="card-body">
                        <h6 class="text-muted mb-3">
                            <i class="bi bi-hospital me-1"></i>Strutture associate
                            <span class="badge bg-light-secondary ms-1"><%= organizzazioni.strutture.length %></span>
                        </h6>

                        <% if (organizzazioni.strutture.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Denominazione</th>
                                            <th class="text-end">Azioni</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% organizzazioni.strutture.forEach((struttura) => { %>
                                            <tr>
                                                <td>
                                                    <i class="bi bi-hospital me-2 text-primary"></i>
                                                    <a href="/strutture/<%= id %>/<%= struttura.id %>"><%= struttura.denominazione %></a>
                                                </td>
                                                <td class="text-end">
                                                    <a href="/strutture/<%= id %>/<%= struttura.id %>" class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-eye me-1"></i>Dettaglio
                                                    </a>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="alert alert-info d-flex align-items-center">
                                <i class="bi bi-info-circle me-2"></i>
                                Nessuna struttura associata a questa organizzazione.
                            </div>
                        <% } %>

                        <div class="mt-3">
                            <a href="/strutture/<%= id %>" class="btn btn-primary">
                                <i class="bi bi-plus-lg me-1"></i>Gestisci Strutture
                            </a>
                        </div>
                    </div>
                </div>
            <% } %>
        </section>
    </div>
</div>
<%- /* Expose server-rendered data as window.SAILS_LOCALS :: */ exposeLocalsToBrowser() %>
