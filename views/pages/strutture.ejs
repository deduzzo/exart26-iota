<div id="strutture" v-cloak>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        let form = document.getElementById('addStrutturaForm');
        if (!form)
          form = document.getElementById('addListaForm');
        form.onsubmit = function (event) {
          event.preventDefault(); // Previene il submit normale del form

          // Validazione
          const denominazione = form.querySelector('#denominazione');
          if (!denominazione.value.trim()) {
            denominazione.classList.add('is-invalid');
            return;
          }
          denominazione.classList.remove('is-invalid');

          // Disabilita il pulsante di submit e mostra il loader
          const submitButton = form.querySelector('button[type="submit"]');
          submitButton.disabled = true;
          document.getElementById('loadingText').style.display = 'inline-block';

          // Prepara i dati del form per l'invio
          const formData = new FormData(form);

          // Effettua la richiesta AJAX
          fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
              'X-CSRF-Token': form.querySelector('[name="_csrf"]').value
            }
          }).then(response => {
            if (response.ok) {
              // Ricarica la pagina se la richiesta ha avuto successo
              window.location.reload();
            } else {
              console.error('Error:', response);
              alert(response);
            }
          }).catch(error => {
            console.error('Error:', error);
            alert(error.error);
          }).finally(() => {
            // Ripristina l'interfaccia utente
            submitButton.disabled = false;
            document.getElementById('loadingText').style.display = 'none';
          });
        };


      });
    </script>

    <% if (organizzazione && !id) { %>
        <!-- Modal Nuova Struttura -->
        <div class="modal fade" id="nuovaStruttura" tabindex="-1" aria-labelledby="modalNuovaStruttura"
             aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-primary bg-opacity-10">
                        <h5 class="modal-title" id="modalNuovaStruttura">
                            <i class="bi bi-plus-circle me-2"></i>Nuova Struttura
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                    </div>
                    <form id="addStrutturaForm" action="/api/v1/add-struttura" method="POST">
                        <input type="hidden" name="_csrf" value="<%- _csrf; %>">
                        <input type="hidden" name="organizzazione" value="<%= organizzazione.id; %>">
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="denominazione" class="form-label fw-semibold">Denominazione</label>
                                <input id="denominazione" name="denominazione" type="text" class="form-control"
                                       placeholder="Nome della struttura sanitaria" required>
                                <div class="invalid-feedback">La denominazione è obbligatoria.</div>
                            </div>
                            <div class="mb-3">
                                <label for="indirizzo" class="form-label fw-semibold">Indirizzo</label>
                                <input id="indirizzo" name="indirizzo" type="text" class="form-control"
                                       placeholder="Via, numero civico, città">
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annulla</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Salva
                            </button>
                            <span id="loadingText" class="ms-2" style="display:none;">
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                Registrazione su blockchain...
                            </span>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    <% } %>

    <% if (id) { %>
        <!-- Modal Nuova Lista -->
        <div class="modal fade" id="nuovaLista" tabindex="-1" aria-labelledby="modalNuovaLista"
             aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-success bg-opacity-10">
                        <h5 class="modal-title" id="modalNuovaLista">
                            <i class="bi bi-plus-circle me-2"></i>Nuova Lista d'Attesa
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Chiudi"></button>
                    </div>
                    <form id="addListaForm" action="/api/v1/add-lista" method="POST">
                        <input type="hidden" name="_csrf" value="<%- _csrf; %>">
                        <input type="hidden" name="struttura" value="<%= strutture.id; %>">
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="denominazione" class="form-label fw-semibold">Denominazione Lista</label>
                                <input id="denominazione" name="denominazione" type="text" class="form-control"
                                       placeholder="Nome della lista d'attesa" required>
                                <div class="invalid-feedback">La denominazione è obbligatoria.</div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Annulla</button>
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg me-1"></i>Salva
                            </button>
                            <span id="loadingText" class="ms-2" style="display:none;">
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                Registrazione su blockchain...
                            </span>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    <% } %>

    <div class="page-content">
        <section class="section">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/organizzazioni">Organizzazioni</a></li>
                    <% if (organizzazione) { %>
                        <% if (!id) { %>
                            <li class="breadcrumb-item active" aria-current="page"><%= organizzazione.denominazione %> - Strutture</li>
                        <% } else { %>
                            <li class="breadcrumb-item"><a href="/strutture/<%= organizzazione.id %>"><%= organizzazione.denominazione %></a></li>
                            <li class="breadcrumb-item active" aria-current="page"><%= strutture.denominazione %></li>
                        <% } %>
                    <% } else { %>
                        <li class="breadcrumb-item active" aria-current="page">Strutture</li>
                    <% } %>
                </ol>
            </nav>

            <% if (!id) { %>
                <!-- Lista strutture -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="mb-1">
                            Strutture
                            <% if (organizzazione) { %>
                                <small class="text-muted fs-6">di <%= organizzazione.denominazione %></small>
                            <% } %>
                        </h3>
                        <p class="text-muted mb-0">Strutture sanitarie e relative liste d'attesa</p>
                    </div>
                    <% if (organizzazione) { %>
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#nuovaStruttura">
                            <i class="bi bi-plus-lg me-1"></i>Nuova Struttura
                        </button>
                    <% } %>
                </div>

                <% if (strutture.length === 0) { %>
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-hospital" style="font-size: 3rem; opacity: 0.3;"></i>
                            <h5 class="mt-3 text-muted">Nessuna struttura presente</h5>
                            <p class="text-muted">
                                <% if (organizzazione) { %>
                                    Aggiungi la prima struttura a questa organizzazione.
                                <% } else { %>
                                    Seleziona un'organizzazione per aggiungere strutture.
                                <% } %>
                            </p>
                        </div>
                    </div>
                <% } else { %>
                    <div class="row">
                        <% strutture.forEach((struttura) => { %>
                            <div class="col-12 col-md-6 col-lg-4 mb-3">
                                <%- include('../layouts/partials/card-struttura', {struttura}); %>
                            </div>
                        <% }); %>
                    </div>
                <% } %>
            <% } %>

            <% if (id) { %>
                <!-- Dettaglio singola struttura -->
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-1">
                                <i class="bi bi-hospital me-2"></i><%= strutture.denominazione %>
                            </h4>
                            <% if (strutture.indirizzo) { %>
                                <small class="text-muted"><i class="bi bi-geo-alt me-1"></i><%= strutture.indirizzo %></small>
                            <% } %>
                        </div>
                        <span class="badge bg-primary">#<%= id %></span>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="text-muted mb-0">
                                <i class="bi bi-list-task me-1"></i>Liste d'Attesa
                                <% if (strutture.liste) { %>
                                    <span class="badge bg-light-secondary ms-1"><%= strutture.liste.length %></span>
                                <% } %>
                            </h6>
                            <button type="button" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#nuovaLista">
                                <i class="bi bi-plus-lg me-1"></i>Nuova Lista
                            </button>
                        </div>

                        <% if (strutture.liste && strutture.liste.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Denominazione</th>
                                            <th class="text-center">Stato</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% strutture.liste.forEach((lista) => { %>
                                            <tr>
                                                <td>
                                                    <i class="bi bi-list-task me-2 text-success"></i>
                                                    <%= lista.denominazione %>
                                                </td>
                                                <td class="text-center">
                                                    <% if (lista.aperta) { %>
                                                        <span class="badge bg-success">
                                                            <i class="bi bi-check-circle me-1"></i>Aperta
                                                        </span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">
                                                            <i class="bi bi-x-circle me-1"></i>Chiusa
                                                        </span>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="alert alert-info d-flex align-items-center">
                                <i class="bi bi-info-circle me-2"></i>
                                Nessuna lista d'attesa presente per questa struttura.
                            </div>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </section>
    </div>
</div>
<%- /* Expose server-rendered data as window.SAILS_LOCALS :: */ exposeLocalsToBrowser(); %>
