<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="card-title mb-0">
                <a href="/assistiti/<%- id %>">
                    <% if (dati) { %>
                        <%- dati.cognome %> <%- dati.nome %>
                    <% } else { %>
                        Assistito #<%- id %>
                    <% } %>
                </a>
            </h5>
            <span class="badge bg-light-primary">#<%- id %></span>
        </div>
        <% if (dati) { %>
            <p class="mb-1"><i class="bi bi-person-vcard me-1"></i> <strong>CF:</strong> <%- dati.codiceFiscale || '-' %></p>
            <% if (dati.email) { %>
                <p class="mb-1 text-muted"><i class="bi bi-envelope me-1"></i> <%- dati.email %></p>
            <% } %>
            <% if (dati.telefono) { %>
                <p class="mb-0 text-muted"><i class="bi bi-telephone me-1"></i> <%- dati.telefono %></p>
            <% } %>
        <% } else { %>
            <p class="text-muted mb-2">Dati non ancora caricati dal blockchain</p>
            <a href="/assistiti/<%- id %>" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-cloud-download me-1"></i> Carica dati
            </a>
        <% } %>
    </div>
</div>
