<div class="card">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="card-title mb-0">
                <a href="/strutture/<%- struttura.organizzazione + '/' + struttura.id %>"><%- struttura.denominazione %></a>
            </h5>
            <span class="badge bg-light-primary">#<%- struttura.id %></span>
        </div>
        <% if (struttura.indirizzo) { %>
            <p class="text-muted mb-2"><i class="bi bi-geo-alt me-1"></i><%- struttura.indirizzo %></p>
        <% } %>
        <% if (struttura.liste && struttura.liste.length > 0) { %>
            <p class="text-muted mb-2"><%= struttura.liste.length %> list<%= struttura.liste.length === 1 ? 'a' : 'e' %></p>
            <ul class="list-group list-group-flush">
                <% struttura.liste.forEach((lista) => { %>
                    <li class="list-group-item px-0 py-1 d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-list-task me-1"></i> <%- lista.denominazione %></span>
                        <% if (lista.aperta) { %>
                            <span class="badge bg-success">Aperta</span>
                        <% } else { %>
                            <span class="badge bg-secondary">Chiusa</span>
                        <% } %>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p class="text-muted mb-0">Nessuna lista associata</p>
        <% } %>
    </div>
</div>
